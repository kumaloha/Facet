# ── 数据库（必填）──────────────────────────────────────────────────────────────
# 开发环境：SQLite
DATABASE_URL=sqlite+aiosqlite:///./data/anchor.db
# 生产环境：阿里云 RDS PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:pass@rm-xxx.pg.rds.aliyuncs.com:5432/anchor

# ── LLM（必填）────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI 兼容模式（Qwen / DeepSeek 等）：
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# ── 平台 Cookie（部署必填，从浏览器 DevTools → Cookies 复制）─────────────────
# 微博：登录 weibo.com → F12 → Application → Cookies，拼接关键字段
# 有效期 ~1-3 个月，过期后重新复制
WEIBO_COOKIE="SUB=xxx; SUBP=yyy; XSRF-TOKEN=zzz"

# B站：登录 bilibili.com → F12 → Application → Cookies
# 有效期 ~6 个月
BILIBILI_COOKIE="SESSDATA=xxx; bili_jct=yyy; buvid3=zzz; buvid_fp=www"

# ── Twitter/X（二选一）────────────────────────────────────────────────────────
# 方式 A（推荐）：自部署 RSSHub，需在 RSSHub 配置 TWITTER_AUTH_TOKEN
#   docker run -d -p 1200:1200 -e TWITTER_AUTH_TOKEN=你的auth_token diygod/rsshub
RSSHUB_URL=http://localhost:1200

# 方式 B：TwitterAPI.io（注册送 100K 免费额度）https://twitterapi.io
TWITTER_API_KEY=
TWITTER_API_BASE=https://api.twitterapi.io

# ── 语音转录（YouTube 音频 → 文字）──────────────────────────────────────────
# 使用 OpenAI Whisper 兼容 API；不填则复用 LLM_API_KEY（OpenAI 模式下自动生效）
# Groq 免费额度极高，推荐：https://console.groq.com  BASE_URL=https://api.groq.com/openai/v1
ASR_API_KEY=
ASR_BASE_URL=
ASR_MODEL=whisper-1              # Groq 用 whisper-large-v3-turbo
YOUTUBE_MAX_DURATION=1800        # 最大转录时长（秒），0=不限制

# ── Embedding（节点归一化预筛用）────────────────────────────────────────────
# 使用 OpenAI 兼容 embedding API；不填则复用 LLM_API_KEY / LLM_BASE_URL
# Anthropic 无 embedding API，需单独配置（如 DashScope text-embedding-v3）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-v3   # DashScope 默认；OpenAI 用 text-embedding-3-small

# ── Batch 模式（Qwen/DashScope 50% 折扣）──────────────────────────────────
# 开启后 LLM 调用走 OpenAI Batch API，异步提交 + 轮询获取结果
# 仅 LLM_PROVIDER=openai 时生效
ENABLE_BATCH=true
BATCH_POLL_INTERVAL=15          # 轮询间隔（秒）
BATCH_MAX_WAIT=3600             # 最大等待时间（秒）

# ── Web Search（Layer3 联网事实核查）─────────────────────────────────────────
# Serper.dev Google Search API（免费 2500 credits）: https://serper.dev
# 不填则 Layer3 仅使用 LLM 训练知识，无联网能力
SERPER_API_KEY=

# ── 宏观数据 API Keys（Layer3 事实核查，均可免费注册）────────────────────────
# FRED API Key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# BLS API Key:  https://www.bls.gov/developers/home.htm
BLS_API_KEY=

# ── Notion 同步（可选）────────────────────────────────────────────────────────
NOTION_API_KEY=

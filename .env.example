# ── 共享数据库 ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/facet.db
ANCHOR_DB_URL=sqlite:///./data/facet.db

# ── LLM（Anchor 提取用）────────────────────────────────────
LLM_PROVIDER=openai
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3.5

# ── Anthropic（可选）────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── 采集 API Keys ──────────────────────────────────────────
TWITTER_BEARER_TOKEN=
WEIBO_COOKIE=

# ── 其他 ────────────────────────────────────────────────────
SERPER_API_KEY=

# Axion 配置
# 复制为 .env 后填写实际值

# ── 数据库 ──────────────────────────────────────────
# 本地开发（SQLite）
ANCHOR_DB_URL=sqlite:///../Anchor/data/anchor.db
AXION_DB_URL=sqlite:///./data/axion.db

# 阿里云部署（PostgreSQL / RDS）
# ANCHOR_DB_URL=postgresql://user:pass@host:5432/anchor
# AXION_DB_URL=postgresql://user:pass@host:5432/axion

# ── 外部数据 API ────────────────────────────────────
# FRED（美联储经济数据）— https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── 运行环境 ────────────────────────────────────────
# local / aliyun
ENV=local
